-- Row helper
local function makeRow(order)
    local row = Instance.new("Frame")
    row.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    row.BorderSizePixel = 0
    row.Size = UDim2.new(1, 0, 0, 52)
    row.LayoutOrder = order
    row.Parent = Content
