-- Row helper
local function makeRow(order, h)
    local row = Instance.new("Frame")
    row.BackgroundColor3 = CARD
    row.BorderSizePixel = 0
    row.Size = UDim2.new(1, 0, 0, h or 46)
    row.LayoutOrder = order
    row.Parent = Content
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke")
    stroke.Color = PURPLE_DARK
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = row
    return row, stroke
end

local function makeSwitch(parent)
    local track = Instance.new("Frame")
    track.BackgroundColor3 = Color3.fromRGB(25, 15, 40)
    track.Position = UDim2.new(1, -40, 0.5, -9)
    track.Size = UDim2.new(0, 32, 0, 17)
    track.ZIndex = 3
    track.Parent = parent
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame")
    knob.BackgroundColor3 = MUTED
    knob.Position = UDim2.new(0, 2, 0.5, -5)
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.ZIndex = 4
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    return track, knob
end

local function setToggle(knob, track, rowStroke, statusLbl, enabled)
    if enabled then
        tw(knob, 0.18, {Position = UDim2.new(1, -12, 0.5, -5), BackgroundColor3 = WHITE})
        tw(track, 0.18, {BackgroundColor3 = PURPLE})
        tw(rowStroke, 0.18, {Color = PURPLE_GLOW})
        statusLbl.Text = "STATUS: ENABLED"
        statusLbl.TextColor3 = PURPLE_GLOW
    else
        tw(knob, 0.18, {Position = UDim2.new(0, 2, 0.5, -5), BackgroundColor3 = MUTED})
        tw(track, 0.18, {BackgroundColor3 = Color3.fromRGB(25, 15, 40)})
        tw(rowStroke, 0.18, {Color = PURPLE_DARK})
        statusLbl.Text = "STATUS: DISABLED"
        statusLbl.TextColor3 = MUTED
    end
end

