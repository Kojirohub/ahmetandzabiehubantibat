end)

ABKeyBtn.MouseButton1Click:Connect(function()
    rebindingAntiBat = true
    ABKeyBtn.Text = "KEY: ..."
end)

GKBtn.MouseButton1Click:Connect(function()
    rebinding = true
    GKBtn.Text = "..."
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if rebinding then
        guiToggleKey = input.KeyCode
        GKBtn.Text = input.KeyCode.Name
        rebinding = false
        return
    end
    if rebindingAntiBat then
        antiBatKey = input.KeyCode
        ABKeyBtn.Text = "KEY: " .. input.KeyCode.Name
        rebindingAntiBat = false
        return
    end
    if input.KeyCode == guiToggleKey then
        Main.Visible = not Main.Visible
    end
    if input.KeyCode == antiBatKey then
        antiBatEnabled = not antiBatEnabled
        if antiBatEnabled then startAntiBat() else stopAntiBat() end
        setToggle(ABKnob, ABTrack, ABStroke, ABStatus, antiBatEnabled)
    end
end)
