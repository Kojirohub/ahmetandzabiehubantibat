-- Visuals
local function updateVisuals()
    if isActive then
        mainFrame.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
        antiLabel.TextColor3 = Color3.fromRGB(20, 20, 20)
        mainStroke.Color = Color3.fromRGB(200, 200, 200)
        mainStroke.Transparency = 0
        mainStroke.Thickness = 1.5
    else
        mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        antiLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        mainStroke.Color = Color3.fromRGB(60, 60, 60)
        mainStroke.Transparency = 0.5
        mainStroke.Thickness = 1.2
    end
end

-- Draggable variables declared early
local dragging = false
local dragStartPos = nil
local frameStartPos = nil
local dragThreshold = 6
local hasDragged = false

-- Toggle
clickButton.MouseButton1Click:Connect(function()
    if hasDragged then return end
    isActive = not isActive
    if isActive then
        startAll()
    else
        stopAll()
    end
    updateVisuals()
end)

-- Respawn
LocalPlayer.CharacterAdded:Connect(function()
    if isActive then
        stopAll()
        task.wait(0.3)
        startAll()
    end
end)

clickButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        hasDragged = false
        dragStartPos = input.Position
        frameStartPos = mainFrame.Position
    end
end)

clickButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
                     input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPos
        if delta.Magnitude > dragThreshold then
            hasDragged = true
        end
        if hasDragged then
            mainFrame.Position = UDim2.new(
                frameStartPos.X.Scale,
                frameStartPos.X.Offset + delta.X,
                frameStartPos.Y.Scale,
                frameStartPos.Y.Offset + delta.Y
            )
        end
    end
end)

updateVisuals()
