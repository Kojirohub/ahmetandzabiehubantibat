-- GUI hide key rebind
TextButton_4.MouseButton1Click:Connect(function()
    rebinding = true
    TextButton_4.Text = "..."
end)

-- Keyboard input
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if rebinding then
        guiToggleKey = input.KeyCode
        TextButton_4.Text = input.KeyCode.Name
        rebinding = false
        return
    end
    if rebindingAntiBat then
        antiBatKey = input.KeyCode
        AntiBatKeyBtn.Text = input.KeyCode.Name
        rebindingAntiBat = false
        return
    end
    if input.KeyCode == guiToggleKey then
        Frame_1.Visible = not Frame_1.Visible
    end
    if input.KeyCode == antiBatKey then
        antiBatEnabled = not antiBatEnabled
        if antiBatEnabled then startAntiBat() else stopAntiBat() end
        setToggleVisual(AntiBatKnob, Frame_9, AntiBatStatus, antiBatEnabled)
    end
end)
