end

local function makeToggleSwitch(parent)
    local track = Instance.new("Frame")
    track.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
    track.Position = UDim2.new(1, -42, 0, 8)
    track.Size = UDim2.new(0, 34, 0, 18)
    track.ZIndex = 3
    track.Parent = parent
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 10)
    local tstroke = Instance.new("UIStroke")
    tstroke.Color = Color3.fromRGB(60, 60, 65)
    tstroke.Parent = track
    local knob = Instance.new("Frame")
    knob.BackgroundColor3 = Color3.fromRGB(80, 80, 85)
    knob.Position = UDim2.new(0, 3, 0.5, -5)
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.ZIndex = 4
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(0, 5)
    return track, knob, tstroke
end

local function setToggleVisual(knob, track, tstroke, statusLabel, enabled)
    if enabled then
        knob.Position = UDim2.new(1, -13, 0.5, -5)
        knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        track.BackgroundColor3 = Color3.fromRGB(80, 200, 120)
        tstroke.Color = Color3.fromRGB(80, 200, 120)
        statusLabel.Text = "STATUS: ENABLED"
        statusLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
    else
        knob.Position = UDim2.new(0, 3, 0.5, -5)
        knob.BackgroundColor3 = Color3.fromRGB(80, 80, 85)
        track.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
        tstroke.Color = Color3.fromRGB(60, 60, 65)
        statusLabel.Text = "STATUS: DISABLED"
        statusLabel.TextColor3 = Color3.fromRGB(190, 190, 195)
    end
end

